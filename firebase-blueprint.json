{
  "entities": {
    "User": {
      "title": "User",
      "description": "App users (drivers)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["driver", "admin"] },
        "pin": { "type": "string", "description": "4-digit PIN for quick access" }
      },
      "required": ["uid", "email", "role"]
    },
    "Shift": {
      "title": "Shift",
      "description": "A driver's working shift",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "driverId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "startKm": { "type": "number" },
        "endKm": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["driverId", "startTime", "startKm", "status"]
    },
    "Telemetry": {
      "title": "Telemetry",
      "description": "GPS and vehicle data points",
      "type": "object",
      "properties": {
        "shiftId": { "type": "string" },
        "driverId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "speed": { "type": "number" },
        "heading": { "type": "number" }
      },
      "required": ["shiftId", "driverId", "timestamp", "latitude", "longitude"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Driver shifts"
    },
    "/telemetry/{telemetryId}": {
      "schema": "Telemetry",
      "description": "GPS data points"
    }
  }
}
