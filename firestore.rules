rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, ['driver', 'admin'])
    //   - pin: string (optional, 4 digits)
    //
    // Collection: shifts
    // Document ID: {shiftId}
    // Fields:
    //   - driverId: string (required)
    //   - startTime: timestamp (required)
    //   - endTime: timestamp (optional)
    //   - startKm: number (required)
    //   - endKm: number (optional)
    //   - status: string (required, ['active', 'completed'])
    //
    // Collection: telemetry
    // Document ID: {telemetryId}
    // Fields:
    //   - shiftId: string (required)
    //   - driverId: string (required)
    //   - timestamp: timestamp (required)
    //   - latitude: number (required)
    //   - longitude: number (required)
    //   - speed: number (optional)
    //   - heading: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "yalcinr896@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      hasRequiredFields(['uid', 'email', 'role']) &&
                      request.resource.data.role == 'driver';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.driverId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.driverId == request.auth.uid &&
                      hasRequiredFields(['driverId', 'startTime', 'startKm', 'status']);
      allow update: if isAuthenticated() && resource.data.driverId == request.auth.uid &&
                      request.resource.data.driverId == resource.data.driverId;
    }

    match /telemetry/{telemetryId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.driverId == request.auth.uid;
    }
  }
}
