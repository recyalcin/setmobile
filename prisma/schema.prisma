// ── Master/Detail Tables ──────────────────────────────────────────────────

model BankAccount {
  id                Int       @id @default(autoincrement())
  bankaccounttypeid Int?
  name              String?
  bankname          String?
  iban              String?
  bic               String?
  personid          Int?
  currencyid        Int?
  isactive          Boolean?
  note              String?
  createdat         DateTime?
  updatedat         DateTime?

  @@map("bankaccount")
}

model DriverActivity {
  id                    Int       @id @default(autoincrement())
  driveractivitytypeid  Int?
  driverid              Int?
  vehicleid             Int?
  tripid                Int?
  datetime              DateTime?
  lat                   Decimal?
  lng                   Decimal?
  odometer              Decimal?
  note                  String?
  createddate           DateTime?
  updateddate           DateTime?

  @@map("driveractivity")
}

model VehicleService {
  id                     Int       @id @default(autoincrement())
  vehicleservicetypeid   Int?
  vehicleid              Int?
  companyid              Int?
  vehicleservicetaskid   Int?
  datetime               DateTime?
  description            String?
  odometer               Decimal?
  totalamount            Decimal?
  invoicenumber          String?
  nextserviceat          DateTime?
  nextserviceodometer    Decimal?
  note                   String?
  createdat              DateTime?
  updatedat              DateTime?

  @@map("vehicleservice")
}

model Transaction {
  id                   Int       @id @default(autoincrement())
  transactiontypeid    Int?
  date                 DateTime?
  fromtypeid           Int?
  fromid               Int?
  totypeid             Int?
  toid                 Int?
  amount               Decimal?
  description          String?
  vehicleid            Int?
  personid             Int?
  note                 String?
  createddate          DateTime?
  updateddate          DateTime?
  officialtypeid       Int?

  @@map("transaction")
}

model CashBox {
  id           Int       @id @default(autoincrement())
  cashboxtypeid Int?
  name         String?
  note         String?
  createddate  DateTime?
  updateddate  DateTime?

  @@map("cashbox")
}

model Company {
  id                   Int       @id @default(autoincrement())
  companytypeid        Int?
  companylegalformid   Int?
  name                 String?
  street               String?
  housenr              String?
  pobox                String?
  city                 String?
  countryid            Int?
  phone                String?
  email                String?
  website              String?
  vatid                String?
  taxid                String?
  bankname             String?
  iban                 String?
  bic                  String?
  note                 String?
  createdat            DateTime?
  updatedat            DateTime?

  @@map("company")
}

// ── Main Tables ────────────────────────────────────────────────────────────

model Person {
  id            Int        @id @default(autoincrement())
  persontypeid  Int?       @default(2)
  firstname     String?
  middlename    String?
  lastname      String?
  email         String?
  phone         String?
  street        String?
  housenr       String?
  pobox         String?
  city          String?
  country       String?
  taxid         String?
  bankname      String?
  iban          String?
  bic           String?
  dateofbirth   DateTime?
  birthcity     String?
  birthcountry  String?
  nationality   String?
  gender        String?
  note          String?
  createdat     DateTime   @default(now())
  updatedat     DateTime?
  users         User[]
  drivers       Driver[]
  employees     Employee[]

  @@map("person")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password      String
  personid      Int?
  active        Boolean  @default(true)
  role          String?  @default("driver")
  remembertoken String?
  createdat     DateTime @default(now())
  person        Person?  @relation(fields: [personid], references: [id])

  @@map("appuser")
}

model Driver {
  id                       Int                 @id @default(autoincrement())
  drivertypeid             Int?
  personid                 Int?
  licensecategoryid        Int?
  licenseissuedate         DateTime?
  licenseexpirydate        DateTime?
  pendorsementissuedate    DateTime?
  pendorsementexpirydate   DateTime?
  note                     String?
  active                   Boolean             @default(true)
  createdat                DateTime?
  updatedat                DateTime?
  person                   Person?             @relation(fields: [personid], references: [id])
  assignments              VehicleAssignment[]
  locations                VehicleLocation[]
  trips                    Trip[]
  performances             Performance[]

  @@map("driver")
}

model Employee {
  id                     Int            @id @default(autoincrement())
  personid               Int?
  employeetypeid         Int?
  employeenumber         String?
  jobtitleid             Int?
  departmentid           Int?
  businessemail          String?
  businessphone          String?
  hiredate               DateTime?
  terminationdate        DateTime?
  note                   String?
  maxmonthlyhours        Int?
  maxweeklyhours         Int?
  workinghoursschichtid  Int?
  active                 Boolean        @default(true)
  createdat              DateTime?
  updatedat              DateTime?
  person                 Person?        @relation(fields: [personid], references: [id])
  workingHours           WorkingHours[]

  @@map("employee")
}

model Vehicle {
  id            Int                 @id @default(autoincrement())
  licenseplate  String?
  makeid        Int?
  modelid       Int?
  colorid       Int?
  vehicletypeid Int?
  active        Boolean             @default(true)
  note          String?
  createdat     DateTime?
  updatedat     DateTime?
  assignments   VehicleAssignment[]
  workingHours  WorkingHours[]
  locations     VehicleLocation[]
  trips         Trip[]

  @@map("vehicle")
}

model VehicleAssignment {
  id           Int       @id @default(autoincrement())
  driverid     Int?
  vehicleid    Int?
  assignedat   DateTime  @default(now())
  unassignedat DateTime?
  driver       Driver?   @relation(fields: [driverid], references: [id])
  vehicle      Vehicle?  @relation(fields: [vehicleid], references: [id])

  @@map("vehicleassignment")
}

model WorkingHours {
  id            Int       @id @default(autoincrement())
  employeeid    Int?
  vehicleid     Int?
  date          DateTime?
  firsttripat   DateTime?
  lasttripat    DateTime?
  workstartat   DateTime?
  workendat     DateTime?
  breakduration String?
  hourstotal    Decimal?
  startkm       Decimal?
  endkm         Decimal?
  recordedat    DateTime?
  note          String?
  createdat     DateTime?
  updatedat     DateTime?
  employee      Employee? @relation(fields: [employeeid], references: [id])
  vehicle       Vehicle?  @relation(fields: [vehicleid], references: [id])

  @@unique([employeeid, date])
  @@map("workinghours")
}

model VehicleLocation {
  id        Int      @id @default(autoincrement())
  vehicleid Int?
  driverid  Int?
  tripid    Int?
  datetime  DateTime @default(now())
  lat       Decimal
  lng       Decimal
  speed     Decimal  @default(0)
  heading   Int?     @default(0)
  accuracy  Decimal?
  note      String?
  createddate DateTime?
  updateddate DateTime?
  driver    Driver?  @relation(fields: [driverid], references: [id])
  vehicle   Vehicle? @relation(fields: [vehicleid], references: [id])

  @@map("vehiclelocation")
}

model Ticket {
  id               Int       @id @default(autoincrement())
  tickettypeid     Int?
  ticketcategoryid Int?
  createdbyid      Int?
  requesterid      Int?
  assignedtoid     Int?
  priorityid       Int?      @default(1)
  ticketstatusid   Int?      @default(1)
  sortorder        Int?
  subject          String?
  description      String?
  dueat            DateTime?
  scheduledat      DateTime?
  resolvedat       DateTime?
  closedat         DateTime?
  driverid         Int?
  vehicleid        Int?
  note             String?
  createdat        DateTime?
  updatedat        DateTime?

  @@map("ticket")
}

model Trip {
  id                        Int       @id
  triptypeid                Int?
  tripstatusid              Int?
  tripsourceid              Int?
  vehicleid                 Int?
  driverid                  Int?
  submittedat               DateTime?
  transmittedat             DateTime?
  respondedat               DateTime?
  pickedupat                DateTime?
  arrivedat                 DateTime?
  latvehiclelocationatorder Decimal?
  lngvehiclelocationatorder Decimal?
  latpickuplocation         Decimal?
  lngpickuplocation         Decimal?
  latdropofflocation        Decimal?
  lngdropofflocation        Decimal?
  pickupdistance            Decimal?
  tripdistance              Decimal?
  fare                      Decimal?
  paymenttypeid             Int?
  note                      String?
  createdat                 DateTime?
  updatedat                 DateTime?
  driver                    Driver?   @relation(fields: [driverid], references: [id])
  vehicle                   Vehicle?  @relation(fields: [vehicleid], references: [id])

  @@map("trip")
}

model Performance {
  id                      Int       @id @default(autoincrement())
  driverid                Int?
  week                    String?
  netearningsbolt         Decimal?
  tollfeesbolt            Decimal?
  ridertipsbolt           Decimal?
  collectedcashbolt       Decimal?
  earningsperformancebolt Decimal?
  finishedridesbolt       Int?
  onlinetimebolt          Decimal?
  totalridedistancebolt   Decimal?
  totalacceptanceratebolt Decimal?
  netearningsuber         Decimal?
  tollfeesuber            Decimal?
  ridertipsuber           Decimal?
  collectedcashuber       Decimal?
  earningsperformanceuber Decimal?
  finishedridesuber       Int?
  onlinetimeuber          Decimal?
  totalridedistanceuber   Decimal?
  totalacceptancerateuber Decimal?
  note                    String?
  createdat               DateTime?
  updatedat               DateTime?
  driver                  Driver?   @relation(fields: [driverid], references: [id])

  @@unique([driverid, week])
  @@map("performance")
}

// ── Additional Tables (not in JSON export but used by PHP modules) ──────────

model EventType {
  id          Int       @id @default(autoincrement())
  name        String?
  note        String?
  createddate DateTime?
  updateddate DateTime?

  @@map("eventtype")
}

model Event {
  id                Int       @id @default(autoincrement())
  eventtypeid       Int?
  name              String?
  date              DateTime?
  timefrom          String?
  timeto            String?
  locationname      String?
  locationmapslink  String?
  note              String?
  createddate       DateTime?
  updateddate       DateTime?

  @@map("event")
}

model Cash {
  id          Int       @id @default(autoincrement())
  cashtypeid  Int?
  amount      Decimal?
  description String?
  entrydate   DateTime?

  @@map("cash")
}
